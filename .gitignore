# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Android
android/
*.keystore
!debug.keystore

# iOS
ios/
*.p8
*.p12
*.mobileprovision

# Firebase / Google Services
# google-services.json is committed — it's client-side config that's included in the APK anyway.
# The actual security is enforced by Firebase security rules, not this file.
service-account.json
firebase-adminsdk-*.json

# Environment variables — NEVER commit
.env
.env.local
.env.production
.env.staging

# EAS secrets
.eas-build-local-nodejs/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Build artifacts
*.apk
*.aab
*.ipa
InternalBytecode.js

# Secrets & keys — never commit these
.env
.env.local
.env.production
service-account.json
*.keystore
*.jks

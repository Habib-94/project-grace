# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Expo ──────────────────────────────────────────────────────────────────────
# .expo/ contains only machine-local state (devices, server config) — never commit
.expo/
dist/
web-build/
# Generated by Expo SDK — rebuild on demand
expo-env.d.ts

# ── Android ───────────────────────────────────────────────────────────────────
# Native android/ folder is generated by `expo prebuild` — do not commit
android/
*.keystore
!debug.keystore
*.jks

# ── iOS ───────────────────────────────────────────────────────────────────────
# Native ios/ folder is generated by `expo prebuild` — do not commit
ios/
*.p8
*.p12
*.mobileprovision

# ── Firebase / Google Services ────────────────────────────────────────────────
# google-services.json / GoogleService-Info.plist are intentionally committed.
# They are client-side config baked into the APK/IPA anyway.
# Security is enforced by Firestore security rules, not by hiding these files.
# DO NOT commit service account keys or admin credentials:
service-account.json
firebase-adminsdk-*.json

# ── Environment variables — NEVER commit ──────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.*.local
*.local

# ── EAS ───────────────────────────────────────────────────────────────────────
.eas-build-local-nodejs/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
# Firebase CLI / emulator logs
firebase-debug.log*
firestore-debug.log*
database-debug.log*
ui-debug.log*
pubsub-debug.log*

# ── Build & bundle artifacts ──────────────────────────────────────────────────
*.apk
*.aab
*.ipa
# Metro/Hermes internal bytecode placeholder
InternalBytecode.js
InternalByteCode.js

# ── Test output ───────────────────────────────────────────────────────────────
coverage/
jest-results/
test-results/

# ── Development-only notes & artifacts ───────────────────────────────────────
REFACTORING_SUMMARY.md
# ─── EAS / Expo ───────────────────────────────────────────────────────────────
# Your EAS project ID (from `eas init` or the Expo dashboard)
EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Path to google-services.json (Android) — download from Firebase console
# Project Settings → Your apps → Android app → google-services.json
GOOGLE_SERVICES_JSON=./google-services.json

# Path to GoogleService-Info.plist (iOS) — download from Firebase console
# Project Settings → Your apps → iOS app → GoogleService-Info.plist
GOOGLE_SERVICES_PLIST=./GoogleService-Info.plist

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Google Maps / Places API key — create in Google Cloud Console
# APIs to enable: Maps SDK for Android, Places API, Geocoding API
# Restrict the key to the app's SHA-1 certificate fingerprint + package name
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ─── API ──────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com

# ─── IMPORTANT ────────────────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in real values.
# 2. NEVER commit .env — it is already in .gitignore.
# 3. For EAS cloud builds use `eas secret:create` instead of setting values
#    directly in eas.json:
#
#    eas secret:create --scope project --name EXPO_PUBLIC_GOOGLE_MAPS_API_KEY --value "AIzaSy..."
#    eas secret:create --scope project --name GOOGLE_SERVICES_JSON --type file --value ./google-services.json
#
# ─── Firebase App Distribution — distribution steps ──────────────────────────
# After a successful EAS preview build:
#
# 1. Download the APK from https://expo.dev/accounts/<account>/projects/<slug>/builds
#    OR run: eas build:list --platform android --profile preview
#
# 2. Install Firebase CLI (if not already):
#    npm install -g firebase-tools
#    firebase login
#
# 3. Distribute the APK:
#    firebase appdistribution:distribute path/to/app.apk \
#      --app <FIREBASE_APP_ID>          \   # From Firebase console → Project settings → Your apps
#      --groups "testers"               \   # Tester group name in App Distribution
#      --release-notes "Build $(date)"
#
# FIREBASE_APP_ID looks like: 1:123456789:android:abcdef1234567890
